{
  "name": "bookcompass",
  "private": true,
  "version": "1.0.20",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "android:sync": "npm run build && cap sync android",
    "android:build": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "android:open": "cap open android",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test": "npm run test:all",
    "build:aab": "npm run test:all && npm run build && cap sync android && cd android && ./gradlew bundleRelease",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.3.0",
    "@capacitor-mlkit/barcode-scanning": "^8.1.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@revenuecat/purchases-capacitor": "^13.2.0",
    "firebase": "^12.14.0",
    "localforage": "^1.10.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
